{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/weaver/schemas/receipt.schema.json",
  "title": "Weaver Receipt",
  "type": "object",
  "required": [
    "receipt_id",
    "receipt_type",
    "status",
    "timestamp_start",
    "timestamp_end",
    "authority_earned",
    "production_allowed"
  ],
  "properties": {
    "receipt_id": { "type": "string" },
    "receipt_type": {
      "type": "string",
      "enum": ["execution", "replay", "promotion", "witness", "authority_review"]
    },
    "gate": { "type": "string" },
    "command": { "type": "string" },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "PENDING"] },
    "exit_code": { "type": "integer" },
    "stdout_hash": { "type": ["string", "null"] },
    "stderr_hash": { "type": ["string", "null"] },
    "timestamp_start": { "type": "string" },
    "timestamp_end": { "type": "string" },
    "environment": { "type": "object" },
    "source_manifest": { "type": ["string", "null"] },
    "output_manifest": { "type": ["string", "null"] },
    "authority_earned": { "type": "boolean", "const": false },
    "production_allowed": { "type": "boolean", "const": false },
    "clinical_allowed": { "type": "boolean", "const": false }
  },
  "additionalProperties": true
}

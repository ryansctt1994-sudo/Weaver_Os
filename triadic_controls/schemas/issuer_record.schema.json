{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triadic.controls/schemas/issuer_record.schema.json",
  "title": "Issuer Record",
  "description": "Cryptographic identity and lifecycle state for an authority or refusal issuer.",
  "type": "object",
  "properties": {
    "issuer_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "key_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "public_key_encoding": {
      "type": "string",
      "enum": ["base64url"]
    },
    "public_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{43}$",
      "description": "Base64url without padding Ed25519 public key, 32 bytes encoded."
    },
    "key_type": {
      "type": "string",
      "enum": ["ed25519"],
      "default": "ed25519"
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "REVOKED", "ROTATED", "SUSPENDED"]
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "rotated_to_key_id": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "revoked_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "revocation_reason": {
      "type": ["string", "null"]
    },
    "assigned_roles": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  },
  "required": [
    "issuer_id",
    "key_id",
    "public_key_encoding",
    "public_key",
    "key_type",
    "status",
    "issued_at",
    "expires_at",
    "assigned_roles"
  ],
  "additionalProperties": false
}

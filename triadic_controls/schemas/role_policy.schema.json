{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triadic.controls/schemas/role_policy.schema.json",
  "title": "Role Policy",
  "description": "Defines authority limits, operational separation, and permissions for a role.",
  "type": "object",
  "properties": {
    "role_id": { "type": "string" },
    "description": { "type": "string" },
    "separation_group": {
      "type": "string",
      "description": "Used to prevent quorum signatures from issuers in the same organizational control group."
    },
    "max_grant_level": { "type": "integer", "minimum": 1, "maximum": 5 },
    "may_grant_authority": { "type": "boolean" },
    "may_revoke_or_refuse": { "type": "boolean" },
    "can_participate_in_quorum": { "type": "boolean" },
    "allowed_scopes": {
      "type": "object",
      "properties": {
        "systems": { "type": "array", "items": { "type": "string" } },
        "regions": { "type": "array", "items": { "type": "string" } },
        "tasks": { "type": "array", "items": { "type": "string" } },
        "max_authority_duration_sec": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "role_id",
    "separation_group",
    "max_grant_level",
    "may_grant_authority",
    "may_revoke_or_refuse",
    "can_participate_in_quorum",
    "allowed_scopes"
  ],
  "additionalProperties": false
}

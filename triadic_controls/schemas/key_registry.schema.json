{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triadic.controls/schemas/key_registry.schema.json",
  "title": "Key Registry",
  "description": "Trusted offline or securely synchronized catalog of issuer records and role policies.",
  "type": "object",
  "properties": {
    "registry_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "registry_version": { "type": "string" },
    "registry_sequence": { "type": "integer", "minimum": 0 },
    "valid_from": { "type": "string", "format": "date-time" },
    "valid_until": { "type": "string", "format": "date-time" },
    "last_updated": { "type": "string", "format": "date-time" },
    "registry_signature": {
      "type": "string",
      "description": "Signature generated by an offline or deployment root key."
    },
    "issuers": {
      "type": "array",
      "items": { "$ref": "issuer_record.schema.json" }
    },
    "roles": {
      "type": "array",
      "items": { "$ref": "role_policy.schema.json" }
    }
  },
  "required": [
    "registry_id",
    "registry_version",
    "registry_sequence",
    "valid_from",
    "valid_until",
    "last_updated",
    "registry_signature",
    "issuers",
    "roles"
  ],
  "additionalProperties": false
}
